{
  "name": "stonewrld",
  "version": "0.1.0",
  "description": "A Dr. Stone-themed pixel-art civilization game that grows from your Claude Code work.",
  "type": "module",
  "author": "Illia Pastushok",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itillushka/StoneWrld.git"
  },
  "homepage": "https://github.com/itillushka/StoneWrld",
  "bugs": {
    "url": "https://github.com/itillushka/StoneWrld/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
