  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/ui": "^2.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  }
